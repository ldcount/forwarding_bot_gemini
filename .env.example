# Telegram API credentials — obtain at https://my.telegram.org/apps
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Your Telegram phone number in international format, e.g. +12025551234
PHONE_NUMBER=+1234567890

# Path (without .session suffix) where Telethon stores the session file.
# Relative to the project root. Directory is created automatically.
SESSION_FILE=data/telegram_forwarder

# Source Telegram chat to monitor.
# Accepts: @username, https://t.me/invite/... invite link, or numeric peer ID (e.g. -1001234567890)
SOURCE_CHAT=@source_channel_username

# Comma-separated list of destinations: groups, channels, or users.
# Same formats accepted as SOURCE_CHAT.
DESTINATIONS=@my_group,@my_channel,-1001234567890

# Set to true to send forwarded messages silently (no notification sound).
FORWARD_SILENT=false

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
